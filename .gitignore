# Only ship gzipped data to keep the repo under GitHub Pages's 1 GB cap.
data/*.json
!data/integrity.json
!data/.gitkeep

# Dev-only pages — not for public visitors
# (kept individually for the existing tracked names; _legacy/ and
# _admin/ patterns below cover future moves into private directories)
old.html
inventory.html
inventory_source.html
issues.html
metadata_audit.html
source_status.html

# Convention: underscore-prefixed top-level dirs are private
# (see workspace-hub/CONVENTIONS.md). _legacy holds retired surfaces;
# _admin holds dev/admin pages not intended for the public Reading Room.
_legacy/
_admin/

# Restricted/copyrighted texts — local only, never push
data/dead-sea-scrolls-*.json
data/dead-sea-scrolls-*.json.gz
data/hesse-siddhartha*.json
data/hesse-siddhartha*.json.gz
data/gospel-ramakrishna*.json
data/gospel-ramakrishna*.json.gz
data/think-grow-rich*.json
data/think-grow-rich*.json.gz

# Local runtime
.server.pid
.claude/
.DS_Store
Thumbs.db
